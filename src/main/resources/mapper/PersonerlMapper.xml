<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.cqie.cqdemo.mapper.PersonerlMapper">
    <select id="selectuser" resultType="edu.cqie.cqdemo.entity.Users">
        SELECT * FROM users where id=#{id}
    </select>
    <select id="selectUserByUsername" resultType="edu.cqie.cqdemo.entity.Users">
        SELECT * FROM users where username=#{username}
    </select>
    <!--    修改手机号-->
    <update id="updateUserphone">
        UPDATE users SET phone=#{phone} WHERE id=#{id}
    </update>
    <!--    修改密码-->
    <update id="updateUserpassword">
        update users set password=#{password} where id=#{id}
    </update>
    <!--    修改邮箱-->
    <update id="updateUseremail">
        update users set email= #{email} where id= #{id}
    </update>
    <!--    修改性别-->
    <update id="updateUsersex">
        update users set gender= #{gender} where id= #{id}
    </update>
    <!--    更新用户信息-->
    <update id="updateUserInfo">
        update users set
                         username = #{username},
                         gender = #{gender},
                         phone = #{phone},
                         email = #{email},
                         per_signature = #{perSignature}
        where id = #{id}
    </update>
<!--    查询店铺-->
    <select id=""></select>
</mapper>

