<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="edu.cqie.cqdemo.mapper.FoodCategoriesMapper">
<!--美食-->
    <select id="getAllStatus" resultType="edu.cqie.cqdemo.entity.FoodCategories">
        SELECT * FROM food_categories ORDER BY created_at DESC;
    </select>
<!--    查询所有美食-->
    <select id="selectFoods" resultType="edu.cqie.cqdemo.entity.Food">
        SELECT * FROM food_categories where status=1;
    </select>

</mapper>