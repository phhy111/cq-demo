<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.cqie.cqdemo.mapper.RegionsMapper">

    <resultMap id="BaseResultMap" type="edu.cqie.cqdemo.entity.Regions">
            <id property="id" column="id" />
            <result property="parentId" column="parent_id" />
            <result property="name" column="name" />
            <result property="level" column="level" />
            <result property="coverImg" column="cover_img" />
            <result property="introduction" column="introduction" />
            <result property="tags" column="tags" />
            <result property="sortOrder" column="sort_order" />
            <result property="status" column="status" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="ext1" column="ext1" />
            <result property="ext2" column="ext2" />
            <result property="ext3" column="ext3" />
            <result property="ext4" column="ext4" />
            <result property="ext5" column="ext5" />
    </resultMap>

    <sql id="Base_Column_List">
        id,parent_id,name,level,cover_img,introduction,
        tags,sort_order,status,created_at,updated_at,
        ext1,ext2,ext3,ext4,ext5
    </sql>
    <!--  查询区域id与区域名称  -->
    <select id="getRegionsIdAndName" resultType="edu.cqie.cqdemo.entity.Regions">
        SELECT `id`,`name`
        FROM `regions`
        ORDER BY `id` ASC;
    </select>
</mapper>
